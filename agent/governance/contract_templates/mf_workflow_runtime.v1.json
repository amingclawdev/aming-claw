  "lane_policy": {
    "green": "all gates pass with deterministic evidence and no runtime/API/dashboard change",
    "yellow": "warnings, env fallback, waiver request, stale token, nonblocking preflight uncertainty, graph-rule/fingerprint change, or runtime/API/dashboard review with E2E -> observer_review",
    "red": "dirty main, same-worktree dispatch, missing evidence, unknown gate, forbidden paths, conflict, runtime/API/dashboard change without E2E, invalid contract, or token mismatch -> blocked"
  },
  "precheck_result_contract": {
    "required_fields": [
      "precheck_run_id",
      "kind",
      "contract_id",
      "stage",
      "decision",
      "status",
      "subject",
      "evidence",
      "evidence_hash",
      "created_at"
    ],
    "allowed_decisions": [
      "allow",
      "review_required",
      "block"
    ],
    "token_policy": "merge, merge_queue_entry, merge_preview, live_merge, reconcile, and close must reference a precheck_run_id whose subject commit/path evidence still matches current state"
  },
  "observer_escalation": {
    "review_stages": [
      "observer_review"
    ],
    "blocked_stages": [
      "blocked"
    ],
    "review_required_reasons": [
      "warnings",
      "waiver_request",
      "graph_rule_change",
      "runtime_or_dashboard_change_with_e2e",
      "nonblocking_preflight_uncertainty"
    ],
    "blocked_reasons": [
      "dirty_main",
      "dirty_worker_outside_scope",
      "same_worktree_dispatch",
      "missing_required_evidence",
      "unknown_gate",
      "invalid_contract",
      "forbidden_path",
      "token_mismatch",
      "runtime_or_dashboard_change_without_e2e"
    ]
  },
  "evidence_requirements": [
    {
      "id": "route_prompt_bundle",
      "required": true,
      "phase": "dispatch",
      "kind": "service_route"
    },
    {
      "id": "route_action_gate",
      "required": true,
      "phase": "pre_mutation",
      "kind": "local_precheck"
    },
    {
      "id": "independent_verification_lane",
      "required": false,
      "phase": "verification",
      "kind": "qa",
      "description": "Required by merge and close prechecks when the route classifies P0/P1 governance, routing, permission, or runtime changes as observer-led parallel lanes."
    },
    {
      "id": "bounded_implementation_worker_dispatch",
      "required": false,
      "phase": "dispatch",
      "kind": "local_precheck",
      "description": "Required by close/precommit gates when route topology is observer_led_parallel_lanes or mf_parallel.v1; must carry the same route_context_hash, prompt_contract_id, and prompt_contract_hash as the route action gate."
    },
    {
      "id": "mf_subagent_startup",
      "required": false,
      "phase": "startup_gate",
      "kind": "local_precheck",
      "description": "Required by close/precommit gates when route topology is observer_led_parallel_lanes or mf_parallel.v1; proves the bounded worker actually started inside the assigned runtime context."
    },
    {
      "id": "graph_trace_evidence",
      "required": false,
      "phase": "dispatch",
      "kind": "graph_query_trace",
      "schema_version": "mf_subagent_graph_trace.v1",
      "description": "Required by dispatch and finish gates for governed nontrivial, Judge-routed, or parent-route-bound mf_sub work; query_source=mf_subagent must be explicit."
    },
    {
      "id": "branch_runtime_registration",
      "required": false,
      "phase": "dispatch",
      "kind": "branch_runtime",
      "schema_version": "mf_subagent_branch_runtime.v1",
      "description": "Required before spawn_agent for governed mf_sub dispatch; records parallel-branches/allocate or upsert_branch_context evidence matching task/fence/worktree/commit/merge queue identity."
    },
    {
      "id": "runtime_context_current_state",
      "required": false,
      "phase": "startup_gate",
      "kind": "runtime_context_projection",
      "schema_version": "runtime_context.current_state_response.v1",
      "description": "Worker-facing lookup for current gate inputs; mf_sub callers must use runtime_context_id plus fence_token and receive only runtime_context.worker_view.v1."
    },
    {
      "id": "observer_subagent_service_dispatch",
      "required": false,
      "phase": "dispatch",
      "kind": "service_dispatch",
      "schema_version": "observer_subagent_service_dispatch.v1",
      "description": "Required by dispatch gate for governed subagent handoff; records replayable command/monitor refs or a documented host-adapter boundary."
    },
    {
      "id": "architecture_review_lane",
      "required": false,
      "phase": "architecture_review",
      "kind": "review_pack",
      "review_pack_template": "architecture_data_continuity_review.v1",
      "description": "Required only when route_topology_policy.required_lanes or instantiated evidence explicitly names architecture_review_lane."
    },
    {
      "id": "qa_evidence_gate_review",
      "required": false,
      "phase": "verification",
      "kind": "review_pack",
      "review_pack_template": "qa_evidence_gate_review.v1",
      "description": "Required only when the route or instantiated contract asks for the QA evidence gate review pack."
    },
    {
      "id": "fixture_contract",
      "required": true,
      "phase": "implementation",
      "kind": "test_fixture"
    },
    {
      "id": "precheck_service_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "workflow_worker_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "merge_close_gate_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "merge_queue_gate_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "compact_precheck_evidence",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "docs_policy_update",
      "required": true,
      "phase": "implementation",
      "kind": "docs"
    },
    {
      "id": "e2e_not_applicable",
      "required": true,
      "phase": "verification",
      "kind": "e2e"
    }
  ]
}

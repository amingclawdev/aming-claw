      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "reconcile",
      "gate_kind": "workflow.reconcile_policy",
      "on_allow": "close_gate",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "close_gate",
      "gate_kind": "backlog.close",
      "on_allow": "done",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    }
  ],

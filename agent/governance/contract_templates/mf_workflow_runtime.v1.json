{
  "schema_version": "mf_workflow_runtime_contract.v1",
  "template_id": "mf_workflow_runtime.v1",
  "version": "v1",
  "description": "Contract for deterministic MF workflow workers that call a unified local precheck/gate service for each privileged stage.",
  "task_types": [
    "mf_parallel",
    "mf_workflow",
    "manual_fix",
    "chain_rescue"
  ],
  "stages": [
    "dispatch",
    "startup_gate",
    "implementation_wait",
    "handoff_gate",
    "merge_gate",
    "merge_queue_entry",
    "merge_preview",
    "live_merge",
    "reconcile",
    "close_gate",
    "pre_close_gate"
  ],
  "contract_instance_id": "",
  "control_plane": {
    "observer_role": "monitoring_requirements_design_exception_handling",
    "worker_role": "deterministic_state_machine_executor",
    "precheck_service_role": "authoritative_gate_decision_and_evidence",
    "timeline_role": "append_only_audit_and_replay_source"
  },
  "route_prompt_contract": {
    "schema_version": "aming_route_prompt_contract.v1",
    "description": "Route-owned visible prompt context and pre-mutation action policy for observer, judger, and bounded implementation lanes.",
    "bundle_schema_version": "aming_route_prompt_alert_bundle.v1",
    "worker_prompt_contract_schema_version": "worker_prompt_contract.v1",
    "visible_injection_manifest_schema_version": "visible_injection_manifest.v1",
    "bundle_service_id": "route.prompt_alert_bundle",
    "action_gate_service_id": "route.action_precheck",
    "action_gate_function": "agent.governance.mf_subagent_contract.validate_route_action_gate",
    "dispatch_gate_function": "agent.governance.mf_subagent_contract.validate_mf_subagent_dispatch_gate",
    "branch_runtime_registration": {
      "schema_version": "mf_subagent_branch_runtime.v1",
      "required_before": "spawn_agent",
      "valid_registration_refs": [
        "/api/graph-governance/{project_id}/parallel-branches/allocate",
        "agent.governance.parallel_branch_runtime.upsert_branch_context"
      ],
      "current_state_refs": [
        "/api/graph-governance/{project_id}/parallel-branches/runtime-contexts/{runtime_context_id}/current-state",
        "aming-claw runtime-context current --project-id {project_id} --runtime-context-id {runtime_context_id} --fence-token {fence_token} --parent-task-id {parent_task_id} --json-output"
      ],
      "description": "Observer allocates/registers branch runtime context before spawn_agent so mf_subagent graph query fence validation can resolve task_id and fence_token."
    },
    "runtime_context_service": {
      "schema_version": "runtime_context.service.entrypoints.v1",
      "current_state_schema_version": "runtime_context.current.v1",
      "gate_inputs_schema_version": "runtime_context.gate_inputs.v1",
      "worker_view_schema_version": "runtime_context.worker_view.v1",
      "close_gate_view_schema_version": "runtime_context.close_gate_view.v1",
      "api_entrypoint": "/api/graph-governance/{project_id}/parallel-branches/runtime-contexts/{runtime_context_id}/current-state",
      "mcp_tool": "runtime_context_current",
      "cli_entrypoint": "aming-claw runtime-context current",
      "worker_required_query_fields": [
        "runtime_context_id",
        "fence_token",
        "parent_task_id"
      ],
      "worker_allowed_sections": [
        "task",
        "branch",
        "route_identity",
        "work",
        "graph_query_identity",
        "gate_inputs",
        "close_gate_view",
        "evidence_refs"
      ],
      "blocked_sections": [
        "observer_only_context",
        "private_context",
        "raw_source_payloads",
        "other_worker_contexts"
      ],
      "source_policy": "Runtime Context Service exposes current-state projections only; route, timeline, graph trace, branch runtime, and contract revision records remain append-only and owner-owned.",
      "privacy_policy": "mf_sub worker view is task-scoped and fence-filtered; raw private Judgment Brain memory and other workers' contexts are never returned."
    },
    "required_hash_fields": [
      "route_context_hash",
      "prompt_contract_id",
      "prompt_contract_hash"
    ],
    "topology_fields": [
      "selected_topology",
      "recommended_topology",
      "required_lanes",
      "reason_codes",
      "observer_authorities",
      "review_pack_templates"
    ],
    "worker_prompt_fields": [
      "target_files",
      "owned_files",
      "test_files",
      "acceptance_criteria",
      "route_identity",
      "evidence_required"
    ],
    "parent_child_runtime_contract": {
      "schema_version": "mf_workflow_runtime.parent_child_runtime_contract.v1",
      "parent_orchestration_required": true,
      "child_prefill_required_before_dispatch": true,
      "prefer_parallel_child_contracts": true,
      "parent_responsibilities": [
        "derive child contracts from the parent route and backlog scope",
        "prefill each child with parent_route_lineage and child route_prompt_contract",
        "bind owned_files, test_commands, branch runtime identity, and merge_queue_id before dispatch",
        "refresh missing or stale child prefill before worker startup"
      ],
      "child_responsibilities": [
        "read runtime_context_worker_guide/current-state before implementation",
        "verify worker_constraints.scope.owned_files matches the dispatch payload",
        "modify only owned_files in the assigned worktree",
        "stop with blocked/review_ready if child prefill or ownership is missing or stale"
      ],
      "dispatch_readiness_fields": [
        "runtime_context_id",
        "task_id",
        "parent_task_id",
        "worker_role",
        "branch_ref",
        "worktree_path",
        "target_project_root",
        "base_commit",
        "target_head_commit",
        "merge_queue_id",
        "fence_token",
        "route_context_hash",
        "prompt_contract_id",
        "prompt_contract_hash",
        "route_token_ref",
        "owned_files",
        "test_commands"
      ],
      "blocked_next_action": "refresh_child_contract_prefill_before_dispatch",
      "missing_or_stale_prefill_message": "Child worker contract prefill is missing or stale; parent orchestration must refresh child route identity, owned_files, and dispatch readiness before implementation."
    },
    "blocked_roles": [
      "observer",
      "judger"
    ],
    "blocked_implementation_actions": [
      "apply_patch",
      "edit_file",
      "edit_files",
      "write_file",
      "implementation_exec",
      "mutate_files",
      "run_implementation_command"
    ],
    "allowance": "bounded worker or subagent dispatch must carry matching route_context_hash, prompt_contract_id, and prompt_contract_hash; observer or judger direct mutation additionally requires an accepted matching waiver",
    "no_raw_context_policy": "route bundle output contains compact summaries, ids, refs, and hashes only; raw prompt, hidden context, observer-only context, and unmanifested injection text are excluded",
    "topology_policy": {
      "low_risk_topology": "lightweight_single_lane",
      "high_risk_topology": "observer_led_parallel_lanes",
      "p0_p1_governance_routing_runtime_requires_independent_verification": true,
      "strategic_judge_routed_optional_lanes": [
        "architecture_review_lane",
        "qa_evidence_gate_review"
      ],
      "review_pack_templates": [
        "architecture_data_continuity_review.v1",
        "qa_evidence_gate_review.v1"
      ],
      "observer_authorities": [
        "merge",
        "redeploy_governance",
        "graph_reconcile",
        "backlog_close",
        "waiver_approval",
        "merge_queue_mutation"
      ]
    }
  },
  "fixture_policy": {
    "decision": "new_scenario_required",
    "fixture_required": true,
    "fixture_path": "agent/tests/fixtures/mf_workflow_runtime.py",
    "scenario_ids": [
      "SCN-MF-WF-001",
      "SCN-MF-WF-002",
      "SCN-MF-WF-003",
      "SCN-MF-WF-004",
      "SCN-MF-WF-005",
      "SCN-MF-WF-006",
      "SCN-MF-WF-007",
      "SCN-MF-WF-008",
      "SCN-MF-WF-009",
      "SCN-MF-WF-010"
    ]
  },

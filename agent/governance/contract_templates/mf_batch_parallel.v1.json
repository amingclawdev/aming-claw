{
  "schema_version": "mf_contract_template.v1",
  "template_id": "mf_batch_parallel.v1",
  "version": "v1",
  "description": "Parent route template for observer-led parallel work across multiple backlog rows. Each row owns worker, independent QA, and protected close evidence; the parent owns one durable, restart-safe integration epoch that serializes merge and final reconcile, then atomically closes the coordination row with the epoch after every child has formally closed.",
  "task_types": [
    "mf_batch_parallel",
    "manual_fix",
    "chain_rescue"
  ],
  "stages": [
    "batch_contract_draft",
    "batch_scope_review",
    "row_fanout_planning",
    "row_successor_dispatch",
    "row_successor_tracking",
    "batch_integration_epoch",
    "ordered_batch_merge",
    "final_batch_reconcile",
    "protected_child_closures",
    "atomic_coordination_epoch_close"
  ],
  "required_instance_fields": [
    "batch_id",
    "backlog_ids",
    "coordination_backlog_id",
    "preflight_id",
    "preflight_hash",
    "merge_queue_plan",
    "row_contracts",
    "conflict_policy",
    "evidence_requirements"
  ],
  "lifecycle_states": [
    "batch_contract_draft",
    "fanout_ready",
    "row_successors_in_progress",
    "integration_epoch_open",
    "merge_in_doubt",
    "final_reconcile_pending",
    "atomic_close_ready",
    "needs_revision",
    "batch_summary_ready",
    "accepted",
    "rejected"
  ],
  "batch_scope_policy": {
    "schema_version": "mf_batch_parallel.scope_policy.v1",
    "multi_backlog_parent": true,
    "coordination_backlog_id_required": true,
    "minimum_backlog_ids": 2,
    "preflight_gate_required_before_fanout_ready": true,
    "preflight_planner_only": true,
    "durable_merge_queue_write_during_preflight": false,
    "first_live_merge_opens_durable_integration_epoch": true,
    "target_ref_frozen_until_atomic_close": true,
    "onboard_active_epoch_precedes_ordinary_backlog_head": true,
    "single_row_successor_contract": "mf_parallel.v2",
    "row_scoped_successor_tokens": true,
    "shared_backlog_close_token_allowed": false,
    "description": "The batch parent never shares one worker token across rows. Rows retain worker, independent QA, and protected close authority. After the first live merge, only the parent-owned canonical epoch cursor may mutate the target ref. Child closes never release the freeze; the coordination close releases it only after all protected child closes and one final reconcile."
  },
  "preflight_gate": {
    "schema_version": "mf_batch_parallel.preflight_gate_contract.v1",
    "interface": "mf_batch_parallel_enter",
    "planner_source": "parallel_branch_runtime.plan_mf_batch_parallel_preflight",
    "required_before_state": "fanout_ready",
    "side_effect_free_preview": true,
    "durable_queue_write": false,
    "required_outputs": [
      "preflight_id",
      "preflight_hash",
      "ordered_rows",
      "overlap_groups",
      "dispatch_groups",
      "merge_queue_plan",
      "blockers"
    ],
    "blocker_policy": {
      "missing_child_rows": "block",
      "closed_or_superseded_child_rows": "block",
      "duplicate_child_rows": "block",
      "missing_target_files": "block",
      "missing_target_head_commit": "block"
    }
  },
  "row_fanout_contract": {
    "schema_version": "mf_batch_parallel.row_fanout_contract.v1",
    "successor_template_id": "mf_parallel.v2",
    "successor_interface": "mf_parallel_enter",
    "required_per_row_fields": [
      "backlog_id",
      "task_id",
      "route_token_ref",
      "owned_files",
      "worker_fence",
      "qa_handoff",
      "merge_queue_id",
      "queue_item_id",
      "queue_index",
      "dependency_fields"
    ],
    "token_policy": {
      "route_token_task_id": "mf_parallel_successor_execution_id",
      "route_token_scope": "single_backlog_row",
      "raw_route_token_exposed": false
    },
    "close_policy": {
      "per_row_close_required": true,
      "child_close_while_epoch_active": "allowed_only_through_own_protected_close",
      "child_close_releases_epoch": false,
      "batch_close_is_summary_only": false,
      "batch_parent_atomic_close_required": true,
      "coordination_close_requires_children_fixed": true,
      "atomic_close_scope": [
        "coordination_backlog_id",
        "integration_epoch"
      ]
    }
  },
  "integration_epoch_contract": {
    "schema_version": "mf_batch_parallel.integration_epoch_contract.v1",
    "open_trigger": "first_live_merge",
    "durable_fields": [
      "project_id",
      "coordination_backlog_id",
      "target_ref",
      "batch_id",
      "base_head",
      "current_head",
      "merge_queue_id",
      "merge_cursor",
      "merged_prefix",
      "remaining_queue_item_ids",
      "reconcile_state"
    ],
    "freeze_policy": {
      "unrelated_same_target_dispatch": "refuse",
      "unrelated_same_target_merge": "refuse",
      "existing_materialized_worker_analysis": "allow",
      "partial_head_as_new_dispatch_base": "refuse",
      "position_skip": "refuse"
    },
    "restart_policy": {
      "next_legal_action": "resume_batch_merge",
      "source": "durable_integration_epoch",
      "merge_in_doubt_resolution": "actual_target_ref_and_ancestry",
      "blind_replay": false
    },
    "final_barrier": {
      "all_queue_items_merged": true,
      "one_current_full_reconcile": true,
      "semantic_projection_optional_when_activation_skips_projection": true,
      "reconcile_failure_keeps_epoch_open": true,
      "child_protected_close_requires_reconciled_epoch": true,
      "all_child_rows_formally_closed_before_coordination_close": true,
      "release_only_in_atomic_coordination_epoch_close": true
    }
  },
  "observer_contract": {
    "mode": "observer_owned_batch_route",
    "observer_direct_code": false,
    "responsibilities": [
      "confirm_batch_backlog_ids",
      "detect_conflicts_between_rows",
      "create_per_row_mf_parallel_successor_plan",
      "track_row_successor_state",
      "summarize_batch_completion",
      "resume_canonical_batch_merge_after_restart",
      "run_one_final_current_full_reconcile",
      "verify_protected_child_closures",
      "close_coordination_and_epoch_atomically"
    ],
    "default_forbidden_actions": [
      "shared_row_token",
      "cross_row_close_without_row_evidence",
      "merge_child_rows_without_row_qa",
      "mutate_child_row_contracts_without_successor_route"
    ]
  },
  "worker_contract": {
    "role": "mf_sub",
    "scope": "single row successor only",
    "description": "Workers do not implement directly against the batch parent. They enter the row-scoped mf_parallel successor that owns their file fence and evidence lines."
  },
  "qa_contract": {
    "role": "qa",
    "scope": "single row successor plus optional batch summary review",
    "independent_verification_required": true
  },
  "evidence_requirements": [
    "preflight_id",
    "preflight_hash",
    "merge_queue_plan",
    "batch_backlog_ids",
    "row_successor_plan",
    "per_row_route_token_refs",
    "per_row_mf_parallel_contract_refs",
    "conflict_policy",
    "batch_summary"
  ],
  "successors": [
    {
      "contract_id": "mf_parallel",
      "version": "v1",
      "reason": "Each backlog row in the batch must continue through a row-scoped mf_parallel successor."
    }
  ]
}

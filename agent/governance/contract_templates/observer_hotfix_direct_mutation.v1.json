{
  "schema_version": "observer_hotfix_direct_mutation_contract.v1",
  "template_id": "observer_hotfix_direct_mutation.v1",
  "version": "v1",
  "description": "Narrow contract for tiny observer hotfix direct mutations when the governed workflow itself is blocked. It records a pre-mutation reason and a post-mutation action summary without weakening verification or close gates.",
  "task_types": [
    "observer_hotfix",
    "manual_fix",
    "chain_rescue"
  ],
  "stages": [
    "pre_mutation",
    "post_implementation",
    "pre_close_gate"
  ],
  "required_instance_fields": [
    "contract_instance_id",
    "backlog_id",
    "allowed_files",
    "blocked_normal_route_evidence",
    "planned_verification"
  ],
  "applicability": {
    "allowed_only_for": "tiny_deterministic_direct_mutation_when_governed_flow_is_blocked",
    "not_for": [
      "governed_nontrivial_implementation",
      "runtime_gate_policy_change",
      "worker_evidence_substitution",
      "route_token_or_close_gate_bypass",
      "architecture_rewrite"
    ],
    "inherits_policy_from": [
      "mf_parallel.v1 observer_contract.direct_mutation_exception_policy",
      "meta_contract.v1 hotfix_profile",
      "manual-fix-sop R18/R22/R24"
    ]
  },
  "timeline_contract": {
    "pre_mutation_reason_event": {
      "event_type": "hotfix.entered",
      "event_kind": "hotfix_entered",
      "phase": "pre_mutation_reason",
      "status_values": [
        "accepted",
        "passed",
        "succeeded"
      ],
      "required_payload_fields": [
        "schema_version",
        "reason",
        "blocked_normal_route_evidence",
        "allowed_files",
        "dirty_scope_before_mutation",
        "planned_verification",
        "forbidden_actions"
      ],
      "required_payload_schema_version": "observer_hotfix_pre_reason.v1",
      "close_satisfying": false,
      "description": "Append before any file mutation. Explains why the normal governed route is blocked, which exact files may be touched, what verification will run, and which actions remain forbidden."
    },
    "post_mutation_action_event": {
      "event_type": "hotfix.under_action",
      "event_kind": "hotfix_under_action",
      "phase": "post_implementation_summary",
      "status_values": [
        "accepted",
        "passed",
        "succeeded"
      ],
      "required_payload_fields": [
        "schema_version",
        "pre_reason_event_id",
        "what_changed",
        "changed_files",
        "verification_evidence_refs",
        "deviations_from_plan",
        "remaining_close_gate_evidence"
      ],
      "required_payload_schema_version": "observer_hotfix_action_summary.v1",
      "close_satisfying": false,
      "description": "Append after the tiny mutation and before close. Records what actually changed and links back to the pre-mutation reason. It is audit evidence, not worker-owned implementation evidence."
    },
    "close_gate_evidence_still_required": [
      "implementation",
      "verification",
      "close_ready"
    ],
    "close_gate_policy": {
      "schema_version": "contract_close_gate_policy.v1",
      "reason": "A direct observer hotfix replaces the bounded implementation worker lane only for tiny deterministic repair of blocked governance flow. It does not replace route service, QA, implementation, verification, close_ready, close-commit, or blocker-resolution gates.",
      "route_context_requirement_overrides": {
        "not_applicable_by_contract": [
          {
            "id": "bounded_implementation_worker_dispatch",
            "reason": "The selected hotfix contract is the audited direct-observer mutation exception; dispatching a bounded implementation worker would be false evidence for the already-completed direct patch."
          },
          {
            "id": "mf_subagent_startup",
            "reason": "The selected hotfix contract is the audited direct-observer mutation exception; worker startup is not applicable and must not be fabricated."
          }
        ],
        "replaced_by_gate": {
          "independent_verification_lane": "independent_qa_gate"
        },
        "still_required": [
          "route_context",
          "route_action_precheck"
        ]
      },
      "qa_policy": {
        "required": true,
        "satisfied_by": [
          "qa_evidence_gate_review.v1",
          "qa_review",
          "qa_verification",
          "independent_verification"
        ],
        "description": "A completed direct hotfix still needs an independent QA successor contract or equivalent independent QA evidence before close."
      },
      "implementation_close_policy": {
        "schema_version": "hotfix_implementation_close_policy.v1",
        "allow_hotfix_under_action_as_implementation": true,
        "default_counts_as_implementation": false,
        "event_kind": "hotfix_under_action",
        "payload_field": "implementation_close_evidence",
        "required_payload_fields": [
          "counts_as_implementation",
          "changed_files",
          "verification_evidence_refs",
          "qa_lineage"
        ],
        "qa_lineage_required": true,
        "description": "hotfix_under_action may satisfy the generic close-gate implementation item only when this policy is active and the event explicitly includes implementation_close_evidence with bounded changed files, verification refs, and QA lineage. Verification, independent QA, and close_ready remain separate gates."
      },
      "close_timeline_evidence_still_required": [
        "implementation",
        "verification",
        "close_ready"
      ],
      "legacy_gate_must_not_weaken": true
    }
  },
  "successor_contract_policy": {
    "schema_version": "successor_contract_policy.v1",
    "selection_required_after_hotfix_complete": true,
    "selection_event_kind": "contract_binding",
    "selection_action": "select_successor_contract",
    "same_row_binding_required": true,
    "separate_backlog_row_allowed_when_successor_has_own_lifecycle": true,
    "required_identity_fields": [
      "contract_chain_id",
      "parent_contract_execution_id",
      "successor_contract_execution_id",
      "handoff_event_id",
      "handoff_reason"
    ],
    "optional_identity_fields": [
      "successor_backlog_id",
      "handoff_preconditions",
      "route_token_ref"
    ],
    "recommended_selection_event_shape": {
      "event_kind": "contract_binding",
      "event_type": "contract.successor.selected",
      "status": "passed",
      "payload": {
        "successor_contract": {
          "contract_chain_id": "<active successor contract_chain_id>",
          "parent_contract_execution_id": "<hotfix active_contract_execution.contract_execution_id>",
          "successor_contract_execution_id": "<new successor execution id>",
          "contract_template_id": "<selected successor contract_template_id>",
          "successor_backlog_id": "<optional successor backlog id>",
          "handoff_event_id": "<timeline event id or external evidence ref>",
          "handoff_reason": "<why this successor is the next contract>"
        }
      },
      "forbidden_root_rebind_fields": [
        "top_level_contract_id",
        "top_level_contract_template_id",
        "top_level_contract_execution_id"
      ],
      "description": "Bind the selected successor inside payload.successor_contract. Do not put successor contract_id or contract_template_id at the payload top level, because top-level contract fields are reserved for root contract revision/binding events."
    },
    "candidates": [
      {
        "id": "mf_parallel.v1",
        "contract_template_id": "mf_parallel.v1",
        "successor_kind": "parallel_worker",
        "description": "Return to ordinary bounded worker implementation when the hotfix only repaired the workflow or established that product work still needs implementation evidence."
      },
      {
        "id": "qa_evidence_gate_review.v1",
        "contract_template_id": "qa_evidence_gate_review.v1",
        "successor_kind": "qa_review",
        "description": "Independent QA evidence review after a completed hotfix or implementation has concrete verification artifacts to inspect."
      },
      {
        "id": "review_contract.v1",
        "contract_template_id": "review_contract.v1",
        "successor_kind": "review",
        "description": "Non-close-satisfying review lane when the hotfix needs design, architecture, or safety assessment before implementation or close."
      },
      {
        "id": "audit_close_with_qa_acceptance.v1",
        "contract_template_id": "audit_close_with_qa_acceptance.v1",
        "successor_kind": "audit_close",
        "description": "Exceptional audit-close successor only for implemented historical rows whose normal close evidence cannot be reconstructed without fabrication."
      }
    ]
  },
  "runtime_contract_hints": {
    "schema_version": "contract_template.runtime_hints.v1",
    "active_contract_identity_fields": [
      "contract_id",
      "contract_template_id",
      "contract_execution_id",
      "contract_chain_id",
      "parent_contract_execution_id",
      "contract_revision_id",
      "route_token_ref"
    ],
    "next_legal_operation_source": "hotfix_contract_evidence_requirements_then_successor_policy",
    "role_bound_prefill_policy": {
      "schema_version": "contract_template.role_bound_prefill_policy.v1",
      "observer_owned_requirements": [
        "hotfix_pre_reason",
        "hotfix_post_action_summary",
        "close_ready",
        "successor_contract_selection"
      ],
      "observer_prefills_non_observer_contracts": [
        "project_id",
        "backlog_id",
        "task_id",
        "contract_execution_id",
        "contract_chain_id",
        "parent_contract_execution_id",
        "route_identity",
        "route_token_ref"
      ],
      "non_observer_execution_evidence_owned_by": {
        "qa": [
          "focused_verification",
          "qa_review",
          "qa_verification",
          "independent_verification"
        ]
      },
      "worker_evidence_substitution_allowed": false
    },
    "close_gate_policy": {
      "schema_version": "contract_template.close_gate_runtime_policy.v1",
      "role": "final_verifier",
      "drives_next_legal_operation": false,
      "next_action_source": "hotfix_contract_state_not_generic_close_gate_gap_list"
    }
  },
  "evidence_requirements": [
    {
      "id": "hotfix_pre_reason",
      "required": true,
      "phase": "pre_mutation",
      "event_kind": "hotfix_entered",
      "accepted_event_kinds": [
        "hotfix_entered"
      ],
      "description": "Pre-mutation timeline reason exists before any allowed file changes."
    },
    {
      "id": "hotfix_post_action_summary",
      "required": true,
      "phase": "post_implementation",
      "event_kind": "hotfix_under_action",
      "accepted_event_kinds": [
        "hotfix_under_action"
      ],
      "description": "Post-mutation timeline summary records what changed and points to verification evidence refs."
    },
    {
      "id": "focused_verification",
      "required": true,
      "phase": "verification",
      "event_kind": "verification",
      "accepted_event_kinds": [
        "verification",
        "qa_verification"
      ],
      "match_policy": "canonical_event_kind",
      "description": "Focused verification remains required after the direct hotfix action; hotfix_under_action cannot satisfy this item."
    },
    {
      "id": "close_ready",
      "required": true,
      "phase": "pre_close_gate",
      "event_kind": "close_ready",
      "accepted_event_kinds": [
        "close_ready"
      ],
      "match_policy": "canonical_event_kind",
      "description": "Close readiness remains a separate required timeline event after implementation and verification evidence are present."
    }
  ],
  "forbidden_capabilities": [
    "author_worker_evidence",
    "bypass_timeline_gate",
    "self_clear_judge_blocker",
    "surrogate_startup",
    "merge",
    "push",
    "release_gates",
    "close_backlog_without_r18_evidence"
  ]
}

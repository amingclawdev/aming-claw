{
  "schema_version": "observer_onboard_contract_template.v1",
  "template_id": "onboard_contract.v1",
  "version": "v1",
  "description": "Observer bootstrap contract that makes the next required observer action explicit before implementation dispatch.",
  "contract_kind": "observer_onboard_contract",
  "task_types": [
    "observer_onboard",
    "manual_fix",
    "chain_rescue"
  ],
  "stages": [
    "observer_bootstrap",
    "design_alignment",
    "pre_implementation"
  ],
  "lifecycle_states": [
    "selected",
    "evidence_in_progress",
    "ready_for_route_transition",
    "ready_for_worker_contract",
    "blocked",
    "complete"
  ],
  "required_evidence": [
    {
      "id": "graph_query_schema_trace",
      "action": "record_graph_query_schema_trace",
      "accepted_event_kinds": [
        "graph_query_schema_trace",
        "route_context"
      ],
      "accepted_statuses": [
        "accepted",
        "ok",
        "passed",
        "succeeded",
        "not_applicable"
      ]
    },
    {
      "id": "related_backlog_review",
      "action": "record_related_backlog_review"
    },
    {
      "id": "observer_root_route_context_read",
      "action": "read_observer_root_route_context"
    },
    {
      "id": "contract_state_projection_read",
      "action": "read_contract_state_projection"
    },
    {
      "id": "route_context",
      "action": "record_route_context",
      "accepted_event_kinds": [
        "route_context"
      ],
      "match_policy": "canonical_event_kind",
      "source": "route_service"
    },
    {
      "id": "route_action_precheck",
      "action": "record_route_action_precheck",
      "accepted_event_kinds": [
        "route_action_precheck"
      ],
      "match_policy": "canonical_event_kind",
      "source": "route_service",
      "prerequisite_ids": [
        "route_context"
      ]
    },
    {
      "id": "observer_work_mode_transition",
      "action": "record_work_mode_transition",
      "prerequisite_ids": [
        "route_context",
        "route_action_precheck"
      ]
    }
  ],
  "conditional_required_evidence": [
    {
      "condition": {
        "target_kind": "generated_demo"
      },
      "evidence": [
        "demo_target_identity_check",
        "demo_graph_status_check",
        "demo_backlog_scope_check",
        "target_file_node_mapping",
        "lane_overlap_scope",
        "dirty_scope_review",
        "demo_root_route_context_read",
        "demo_contract_state_gap_detected",
        "worker_contract_after_onboard"
      ]
    }
  ],
  "requirement_semantics": {
    "schema_version": "contract_requirement_semantics.v1",
    "runtime_must_not_hardcode_template_ids": true,
    "projection_is_read_only": true,
    "writes_use_timeline_adapter": true,
    "requirement_fields": [
      "id",
      "condition",
      "prerequisite_ids",
      "accepted_event_kinds",
      "accepted_statuses",
      "blocked_by",
      "action",
      "source",
      "precedence"
    ]
  },
  "next_action_policy": {
    "schema_version": "contract_state_next_action_policy.v2",
    "first_missing_required_evidence_drives_next_legal_action": true,
    "generic_close_gate_repairs_deferred_until_active_contract_complete": true,
    "precedence": [
      "active_contract_missing_step",
      "route_identity_or_precheck",
      "observer_work_mode",
      "worker_dispatch",
      "merge_or_close_repair"
    ]
  },
  "active_contract_execution_schema": {
    "schema_version": "active_contract_execution.v1",
    "required_fields": [
      "project_id",
      "backlog_id",
      "contract_execution_id",
      "contract_id",
      "contract_template_id",
      "contract_revision_id",
      "state",
      "projection_watermark",
      "route_identity_hash"
    ],
    "optional_fields": [
      "contract_instance_id",
      "observer_session_id",
      "route_token_ref",
      "prompt_contract_id",
      "visible_injection_manifest_hash"
    ]
  },
  "successor_contract_policy": {
    "schema_version": "successor_contract_policy.v1",
    "selection_required_after_onboard_complete": true,
    "selection_event_kind": "contract_binding",
    "selection_action": "select_successor_contract",
    "same_row_binding_required": true,
    "separate_backlog_row_allowed_when_successor_has_own_lifecycle": true,
    "required_identity_fields": [
      "contract_chain_id",
      "parent_contract_execution_id",
      "successor_contract_execution_id",
      "handoff_event_id",
      "handoff_reason"
    ],
    "optional_identity_fields": [
      "successor_backlog_id",
      "handoff_preconditions",
      "route_token_ref"
    ],
    "recommended_selection_event_shape": {
      "event_kind": "contract_binding",
      "event_type": "contract.successor.selected",
      "status": "passed",
      "payload": {
        "successor_contract": {
          "contract_chain_id": "<root active_contract_execution.contract_chain_id>",
          "parent_contract_execution_id": "<root active_contract_execution.contract_execution_id>",
          "successor_contract_execution_id": "<new successor execution id>",
          "contract_template_id": "<selected successor contract_template_id>",
          "successor_backlog_id": "<optional successor backlog id>",
          "handoff_event_id": "<timeline event id or external evidence ref>",
          "handoff_reason": "<why this successor is the next contract>"
        }
      },
      "forbidden_root_rebind_fields": [
        "top_level_contract_id",
        "top_level_contract_template_id",
        "top_level_contract_execution_id"
      ],
      "description": "Bind the selected successor inside payload.successor_contract. Do not put successor contract_id or contract_template_id at the payload top level, because top-level contract fields are reserved for root contract revision/binding events."
    },
    "candidates": [
      {
        "id": "observer_hotfix_direct_mutation.v1",
        "contract_template_id": "observer_hotfix_direct_mutation.v1",
        "successor_kind": "observer_hotfix",
        "description": "Tiny deterministic observer hotfix when the governed normal route is blocked. Non-close-satisfying; must hand off to review or close successor afterward."
      },
      {
        "id": "mf_parallel.v1",
        "contract_template_id": "mf_parallel.v1",
        "successor_kind": "parallel_worker",
        "description": "Ordinary bounded worker/parallel implementation successor for nontrivial work."
      },
      {
        "id": "review_contract.v1",
        "contract_template_id": "review_contract.v1",
        "successor_kind": "review",
        "description": "Top-level or nested non-close-satisfying review lane."
      },
      {
        "id": "audit_close_with_qa_acceptance.v1",
        "contract_template_id": "audit_close_with_qa_acceptance.v1",
        "successor_kind": "audit_close",
        "description": "Exceptional audit-close successor only when normal close has failed and evidence cannot be reconstructed."
      }
    ]
  },
  "write_authority_policy": {
    "schema_version": "contract_state_write_authority.v1",
    "projection_module_may_write": false,
    "write_facade_scope": "timeline_server_mcp_adapter_only",
    "raw_route_tokens_persisted": false,
    "append_only_timeline_required": true
  },
  "generated_demo_policy": {
    "schema_version": "generated_demo_onboard_policy.v1",
    "required_only_when_target_kind": "generated_demo",
    "must_confirm_target_project_is_not_aming_claw_repo": true,
    "must_record_ephemeral_fixture_root_warning": true,
    "must_classify_unmapped_assets_and_planned_new_files": true,
    "must_classify_dirty_generated_metadata": true,
    "successor_contract_must_be_selected_after_onboard": true,
    "worker_prompt_must_not_include_aming_claw_repo_implementation_context": true
  },
  "dogfood_policy": {
    "schema_version": "onboard_contract_dogfood_policy.v1",
    "after_redeploy": true,
    "target_kind": "generated_demo",
    "happy_path_may_block": true,
    "record_blocker_as_contract_state_gap": true
  }
}

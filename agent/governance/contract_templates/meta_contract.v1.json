{
  "schema_version": "meta_contract.v1",
  "id": "meta_contract.v1",
  "description": "Role/action whitelist for governed timeline evidence. Observer identity is never a whitelist bypass.",
  "enforcement": {
    "surface": "task_timeline_events.record_event",
    "storage_model": "existing_task_timeline_events",
    "observer_events_validated": true,
    "skip_paths": []
  },
  "forbidden_always": [
    "author_worker_evidence",
    "self_fix_and_close",
    "bypass_timeline_gate",
    "self_waiver",
    "self_clear_judge_blocker",
    "surrogate_startup",
    "fork_identity_to_launder"
  ],
  "worker_evidence_actions": [
    "implementation",
    "mf_subagent_startup",
    "record_finish_time_worker_attestation",
    "read_receipt",
    "review_ready",
    "worker_progress",
    "patch"
  ],
  "forbidden_evidence_recording_actions": [
    "forbidden_attempt_recorded"
  ],
  "role_action_whitelist": {
    "observer": {
      "allowed_actions": [
        "route_context",
        "route_identity_cleanup",
        "route_action_precheck",
        "design_review",
        "architecture_review",
        "review_lane",
        "plan_precheck",
        "adversarial_review",
        "observer_work_mode_transition",
        "dispatch_bounded_worker",
        "merge_preview",
        "merge_queue_entry",
        "live_merge",
        "merge",
        "reconcile",
        "record_blocker",
        "close_ready",
        "close_after_clauses",
        "hotfix_entered",
        "hotfix_under_action",
        "observer_command",
        "cross_ref_lineage_bridge",
        "lineage_bridge",
        "route_token_gate",
        "no_progress_timeout",
        "forbidden_attempt_recorded"
      ],
      "worker_evidence_requires": {
        "on_behalf_of": true,
        "self_attesting": false
      }
    },
    "worker": {
      "aliases": [
        "mf_sub",
        "subagent",
        "implementation_worker",
        "bounded_implementation_worker"
      ],
      "allowed_actions": [
        "read_receipt",
        "mf_subagent_startup",
        "record_finish_time_worker_attestation",
        "implementation",
        "review_ready",
        "worker_progress",
        "patch",
        "close_ready",
        "record_blocker",
        "graph_trace"
      ]
    },
    "mf_sub": {
      "aliases": [
        "worker",
        "subagent",
        "implementation_worker",
        "bounded_implementation_worker"
      ],
      "allowed_actions": [
        "read_receipt",
        "mf_subagent_startup",
        "record_finish_time_worker_attestation",
        "implementation",
        "review_ready",
        "worker_progress",
        "patch",
        "close_ready",
        "record_blocker",
        "graph_trace"
      ]
    },
    "qa": {
      "allowed_actions": [
        "independent_verification",
        "qa_verification",
        "qa_review",
        "record_blocker",
        "review_ready"
      ]
    },
    "judge": {
      "allowed_actions": [
        "design_review",
        "architecture_review",
        "review_lane",
        "plan_precheck",
        "adversarial_review",
        "independent_verification",
        "qa_review",
        "record_blocker",
        "forbidden_attempt_recorded"
      ]
    },
    "system": {
      "allowed_actions": [
        "service_route",
        "route_token_gate",
        "observer_command",
        "no_progress_timeout",
        "forbidden_attempt_recorded",
        "record_blocker",
        "hotfix_entered",
        "hotfix_under_action",
        "stale_artifact_cleanup"
      ]
    },
    "operator": {
      "allowed_actions": [
        "hotfix_entered",
        "hotfix_under_action",
        "record_blocker",
        "close_after_clauses"
      ]
    }
  },
  "hotfix_profile": {
    "profile": "HOTFIX",
    "entry_event_type": "hotfix.entered",
    "entry_event_kind": "hotfix_entered",
    "requires_human_reason": true,
    "under_action_requires_entry": true,
    "under_action_requires_ref": true,
    "under_action_requires_reason": true,
    "subsequent_action_tag": "under_hotfix",
    "query_view": "/api/projects/{project_id}/hotfix/usage",
    "silent_bypass_allowed": false
  }
}

{
  "schema_version": "direct_fix_contract_template.v1",
  "template_id": "direct_fix.v1",
  "version": "v1",
  "description": "Contract-driven successor lane for operator-supervised repair of a blocked parent contract. It freezes parent identity, scopes repair to the blocker, requires independent QA, and returns to the parent without satisfying parent close by itself.",
  "task_types": [
    "direct_fix",
    "observer_direct_fix",
    "chain_rescue",
    "manual_fix"
  ],
    "stages": [
        "blocked_parent_handoff",
        "operator_approval",
        "observer_graph_scope",
        "candidate_branch",
        "worker_graph_context",
        "repair_implementation",
        "qa_graph_context",
        "qa_verification",
        "return_to_parent"
    ],
  "required_instance_fields": [
    "contract_instance_id",
    "backlog_id",
    "parent_contract_execution_id",
    "blocked_gate",
    "return_to_contract_id",
    "return_to_stage_id",
    "return_to_line_id",
    "allowed_files",
    "operator_approval_ref",
    "successor_route_token_ref"
  ],
  "applicability": {
    "allowed_only_for": "blocked_parent_contract_runtime_or_governance_gate_repair",
    "not_for": [
      "root_onboarding",
      "general_observer_direct_main",
      "parent_close_gate_satisfaction",
      "unscoped_product_implementation",
      "raw_route_token_storage",
      "candidate_graph_activation_as_target_truth"
    ],
    "eligibility_requires": [
      "parent_contract_execution_id",
      "blocked_parent_next_action",
      "operator_approval_scope",
      "successor_scoped_route_token_ref"
    ]
  },
  "timeline_contract": {
    "handoff_event": {
      "event_type": "direct_fix.entered",
      "event_kind": "contract_binding",
      "phase": "direct_fix",
      "close_satisfying": false,
      "required_payload_fields": [
        "parent_contract_execution_id",
        "successor_contract_execution_id",
        "blocked_gate",
        "return_to_parent",
        "route_token_ref"
      ]
    },
    "return_event": {
      "event_type": "direct_fix.return_to_parent",
      "event_kind": "direct_fix_return_to_parent",
      "phase": "return_to_parent",
      "close_satisfying": false,
      "required_payload_fields": [
        "parent_contract_execution_id",
        "successor_contract_execution_id",
        "qa_evidence_refs",
        "parent_close_gate_recheck_required"
      ]
    },
    "close_gate_evidence_still_required": [
      "implementation",
      "verification",
      "close_ready"
    ]
  },
  "gate_policy": {
    "schema_version": "direct_fix_gate_policy.v1",
    "root_start_allowed": false,
    "parent_blocked_handoff_required": true,
    "operator_approval_required": true,
        "successor_route_token_ref_required": true,
        "observer_graph_scope_required_before_dispatch": true,
        "worker_graph_context_required_before_repair": true,
        "qa_graph_context_required_before_verification": true,
        "independent_qa_required": true,
        "parent_close_gate_recheck_required": true,
        "child_must_not_write_parent_close_evidence": true
  },
  "runtime_contract_hints": {
    "schema_version": "contract_template.runtime_hints.v1",
    "contract_definition_id": "direct_fix",
    "contract_definition_revision": "rev1",
        "entrypoint": "direct_fix_enter",
        "blocked_parent_projection": true,
        "graph_query_checkpoints": [
            {
                "id": "observer_graph_scope",
                "line_id": "direct_fix_observer_graph_scope",
                "owner_role": "observer",
                "event_kind": "graph_trace",
                "required_before": "direct_fix_dispatch_context",
                "packet": {
                    "query_source": "observer",
                    "query_purpose": "observer_scope_build",
                    "required_fields": [
                        "project_id",
                        "backlog_id",
                        "contract_execution_id",
                        "target_project_root",
                        "graph_trace_ids",
                        "graph_trace_evidence.db_verified"
                    ]
                }
            },
            {
                "id": "worker_graph_context",
                "line_id": "direct_fix_worker_graph_context",
                "owner_role": "mf_sub",
                "event_kind": "graph_trace",
                "required_before": "direct_fix_candidate_repair",
                "packet": {
                    "query_source": "mf_subagent",
                    "query_purpose": "subagent_context_build",
                    "worker_role": "mf_sub",
                    "required_fields": [
                        "runtime_context_id",
                        "task_id",
                        "parent_task_id",
                        "target_project_root",
                        "graph_trace_ids",
                        "graph_trace_evidence.db_verified"
                    ]
                }
            },
            {
                "id": "qa_graph_context",
                "line_id": "direct_fix_qa_graph_context",
                "owner_role": "qa",
                "event_kind": "graph_trace",
                "required_before": "qa_independent_verification",
                "packet": {
                    "query_source": "qa",
                    "query_purpose": "independent_verification",
                    "required_fields": [
                        "target_project_root",
                        "graph_trace_ids",
                        "graph_trace_evidence.db_verified",
                        "graph_trace_evidence.graph_basis",
                        "graph_trace_evidence.canonical_base_snapshot_id",
                        "graph_trace_evidence.base_commit_sha",
                        "graph_trace_evidence.candidate_commit_sha",
                        "graph_trace_evidence.changed_files",
                        "graph_trace_evidence.candidate_diff_hash",
                        "graph_trace_evidence.changed_files_source",
                        "graph_trace_evidence.candidate_overlay_hash",
                        "graph_trace_evidence.root_identity_hash",
                        "graph_trace_evidence.query_root_identity_hash",
                        "graph_trace_evidence.canonical_project_identity_hash",
                        "graph_trace_evidence.repository_identity_hash"
                    ],
                    "graph_basis_policy": {
                        "accepted": [
                            "exact_candidate_snapshot",
                            "canonical_base_plus_candidate_diff"
                        ],
                        "authority": "contract_definition.system_layer.graph_binding_policy.bounded_qa_review_policy",
                        "caller_authority_fields_trusted": false,
                        "candidate_diff_derivation": "server_only",
                        "candidate_overlay_derivation": "server_git_objects_and_language_adapters",
                        "non_authoritative_template_mirror": true,
                        "unsafe_overlay_policy": "require_exact_candidate_snapshot",
                        "full_candidate_snapshot_required": false
                    }
                }
            }
        ],
        "migration_policy": {
            "active_execution_rewrite": "forbidden",
            "same_revision_definition_hash_drift": "stale_pinned_execution_error",
            "new_graph_checkpoints_apply_to": "new_direct_fix_executions_only"
        },
        "return_to_parent": {
            "required": true,
            "parent_close_gate_recheck_required": true
        }
  },
  "evidence_requirements": [
    {
      "id": "direct_fix_handoff_request",
      "owner_role": "observer",
      "event_kind": "direct_fix_handoff_request"
    },
        {
            "id": "direct_fix_operator_approval",
            "owner_role": "observer",
            "event_kind": "operator_approval"
        },
        {
            "id": "direct_fix_observer_graph_scope",
            "owner_role": "observer",
            "event_kind": "graph_trace"
        },
        {
            "id": "direct_fix_dispatch_context",
            "owner_role": "observer",
            "event_kind": "dispatch_bounded_worker"
        },
        {
            "id": "direct_fix_worker_graph_context",
            "owner_role": "mf_sub",
            "event_kind": "graph_trace"
        },
        {
            "id": "direct_fix_candidate_repair",
            "owner_role": "mf_sub",
            "event_kind": "direct_fix_repair_evidence",
            "required_fields": [
                "commit_sha"
            ]
        },
        {
            "id": "direct_fix_qa_graph_context",
            "owner_role": "qa",
            "event_kind": "graph_trace"
        },
        {
            "id": "qa_independent_verification",
            "owner_role": "qa",
      "event_kind": "independent_verification"
    },
    {
      "id": "direct_fix_return_to_parent",
      "owner_role": "observer",
      "event_kind": "direct_fix_return_to_parent"
    }
  ],
  "forbidden_capabilities": [
    "bypass_parent_close_gate",
    "generalize_observer_direct_main",
    "store_raw_route_token",
    "activate_candidate_graph_as_target_truth",
    "self_author_independent_qa"
  ]
}

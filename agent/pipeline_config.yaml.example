# Pipeline Multi-Provider Configuration Example
#
# Copy this file to pipeline_config.yaml and place it in one of these locations:
#   shared-volume/codex-tasks/state/pipeline_config.yaml
#
# Supported provider values (including aliases):
#   anthropic (aliases: opus, claude)
#   openai    (aliases: codex, gpt)
#
# Environment variable overrides (take precedence over config file):
#   PIPELINE_DEFAULT_PROVIDER  - override default provider
#   PIPELINE_DEFAULT_MODEL     - override default model
#   PIPELINE_ROLE_PM_PROVIDER  - override PM role provider
#   PIPELINE_ROLE_PM_MODEL     - override PM role model
#   PIPELINE_ROLE_DEV_PROVIDER / PIPELINE_ROLE_DEV_MODEL
#   PIPELINE_ROLE_TEST_PROVIDER / PIPELINE_ROLE_TEST_MODEL
#   PIPELINE_ROLE_QA_PROVIDER  / PIPELINE_ROLE_QA_MODEL
#   PIPELINE_ROLE_COORDINATOR_PROVIDER / PIPELINE_ROLE_COORDINATOR_MODEL
#   PIPELINE_ROLE_UTILITY_PROVIDER / PIPELINE_ROLE_UTILITY_MODEL

pipeline:
  # Default config - roles without individual config will use this
  default:
    provider: anthropic
    model: claude-sonnet-4-6

  # Role-level config - overrides default config
  roles:
    coordinator:
      provider: anthropic
      model: claude-sonnet-4-6     # fast routing / decision-only role
    pm:
      provider: anthropic
      model: claude-opus-4-6       # PM reads code and outputs PRD
    dev:
      provider: anthropic
      model: claude-opus-4-6       # Claude path with stronger implementation reasoning
    tester:
      provider: anthropic
      model: claude-sonnet-4-6
    qa:
      provider: anthropic
      model: claude-opus-4-6
    gatekeeper:
      provider: anthropic
      model: claude-sonnet-4-6
    utility:
      provider: anthropic
      model: claude-sonnet-4-6

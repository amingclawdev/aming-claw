{
  "mcpServers": {
    "aming-claw": {
      "command": "python",
      "args": ["-m", "agent.mcp.server", "--project", "aming-claw", "--workers", "0", "--governance-url", "http://localhost:40000"],
      "cwd": ".",
      "env": {
        "PYTHONDONTWRITEBYTECODE": "1",
        "PYTHONUNBUFFERED": "1",
        "GOVERNANCE_URL": "http://localhost:40000",
        "MANAGER_URL": "http://127.0.0.1:40101",
        "MEMORY_BACKEND": "docker"
      }
    }
  }
}

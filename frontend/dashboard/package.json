{
  "name": "aming-claw-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "aming-claw governance dashboard P0 — operational view of graph snapshots, semantic projection, and operations queue",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/sync-dist-to-python-package.mjs",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc -b --noEmit",
    "e2e:projects": "node scripts/e2e-projects.mjs",
    "e2e:semantic": "node scripts/e2e-semantic.mjs",
    "e2e:trunk": "node scripts/e2e-trunk.mjs"
  },
  "dependencies": {
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}

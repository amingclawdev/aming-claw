# Backend governance service base URL.
# Used by Vite dev proxy AND by the API client when calling without the proxy.
VITE_BACKEND_URL=http://localhost:40000

# Project id consumed by graph-governance endpoints.
VITE_PROJECT_ID=aming-claw

# When true, the API client hits VITE_BACKEND_URL directly (relies on backend CORS).
# When false (default), it goes through the Vite dev proxy at /api.
VITE_DIRECT_API=false

# Absolute path to the repository on the user's machine. When set, file paths
# in the inspector become clickable links that open in your editor. When
# unset, the dashboard renders file paths as plain text + "copy path" button.
# Use forward slashes, even on Windows.
VITE_WORKSPACE_ROOT=C:/Users/z5866/Documents/amingclaw/aming_claw

# Which editor's URI scheme to emit. One of:
#   vscode (default) | vscode-insiders | cursor
#   jetbrains-idea | jetbrains-pycharm
VITE_EDITOR_SCHEME=vscode

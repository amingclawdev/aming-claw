{
  "schema_version": "task_timeline_semantic_catalog.v1",
  "fallback": {
    "title": "System timeline event",
    "detail": "A governance timeline event was recorded. Public fields are shown in the detail chips.",
    "chip_paths": [
      { "label": "event type", "path": "event_type" },
      { "label": "event kind", "path": "event_kind" },
      { "label": "phase", "path": "phase" },
      { "label": "status", "path": "status" },
      { "label": "actor", "path": "actor" }
    ],
    "evidence_paths": [
      { "kind": "timeline_event", "label": "event", "path": "event_id" },
      { "kind": "graph_trace", "label": "trace", "path": "trace_id" },
      { "kind": "commit", "label": "commit", "path": "commit_sha" }
    ],
    "artifact_paths": [],
    "detail_paths": [
      { "label": "task", "path": "task_id" },
      { "label": "backlog", "path": "backlog_id" },
      { "label": "correlation", "path": "correlation_id" }
    ]
  },
  "status_labels": {
    "accepted": "accepted",
    "acknowledged": "acknowledged",
    "blocked": "blocked",
    "complete": "complete",
    "completed": "completed",
    "failed": "failed",
    "missing": "missing",
    "passed": "passed",
    "pending": "pending",
    "queued": "queued",
    "ready": "ready",
    "recorded": "recorded",
    "requested": "requested",
    "running": "running",
    "started": "started",
    "upserted": "upserted"
  },
